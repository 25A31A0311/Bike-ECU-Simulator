#include <stdio.h>
#include "engine.h"

void ignition(BikeEngine *e) {
    if (!e->is_started) {
        e->is_started = 1;
        e->rpm = 1200; // Bike idle is usually higher than cars
        printf("Engine fired up. Idling at 1200 RPM.\n");
    }
}

void apply_throttle(BikeEngine *e, int amount) {
    if (e->is_started) {
        e->throttle_pos = amount;
        e->rpm += (amount * 50); // Simple linear RPM increase
        e->temperature += (amount / 10);
        printf("Throttle at %d%%. RPM: %d\n", amount, e->rpm);
    }
}
